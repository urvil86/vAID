# ============================================================================
# V-Aid — environment template
#
# Copy to .env for local dev, or set these as environment variables on your
# host (Vercel/Neon, etc.) for production. See apps/web/DEPLOY.md.
# ============================================================================

# ── Database (REQUIRED) ─────────────────────────────────────────────────────
# Production: a Neon Postgres connection string (the @neondatabase/serverless
# driver talks to Neon directly — do NOT set NEON_LOCAL_PROXY in prod).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ── Auth (REQUIRED) ─────────────────────────────────────────────────────────
# Must be your real HTTPS origin in production (cookies are Secure + SameSite=None
# and will NOT work over plain HTTP).
BETTER_AUTH_URL=https://your-domain.com
# Generate a fresh one: `openssl rand -base64 48`
BETTER_AUTH_SECRET=__CHANGE_ME__

# ── AI structuring + translation (OpenRouter / Gemini) ──────────────────────
# Leave OPENROUTER_API_KEY empty to fall back to deterministic local structuring.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
# Data minimisation: set to 1 to keep ALL health data in-house (skips every
# external model and uses only deterministic local structuring — no transcript
# leaves your infrastructure). Recommended if you can't sign a DPA with Google.
DISABLE_THIRD_PARTY_AI=

# ── Anything platform (optional) ────────────────────────────────────────────
# Only needed if you route AI via the platform's Claude proxy instead of OpenRouter.
ANYTHING_PROJECT_TOKEN=
# NEXT_PUBLIC_CREATE_BASE_URL=

# ── Speech-to-text (optional; pending integration) ──────────────────────────
# When set, server-side Sarvam STT can replace the browser Web Speech API.
SARVAM_API_KEY=

# ============================================================================
# LOCAL-DEV ONLY — never set these in production
# ============================================================================
# Points the Neon driver at the local proxy container instead of Neon Cloud.
# NEON_LOCAL_PROXY=localhost:4444
# Auth bypass for local testing (super-user). MUST be removed in production.
# DEV_AUTH_BYPASS=1
# NEXT_PUBLIC_DEV_AUTH_BYPASS=1
# PWA service worker is OPT-IN and off by default (no worker is registered).
# Only enable once a real caching sw.js is shipped:
# NEXT_PUBLIC_ENABLE_PWA=1
